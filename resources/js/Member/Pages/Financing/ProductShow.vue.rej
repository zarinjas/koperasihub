                     </div>
                 </div>
 
                 <div class="mt-6 grid gap-6 md:grid-cols-2">
                     <div class="space-y-5">
                         <div>
                             <label class="text-sm font-medium text-slate-800">Jumlah Pembiayaan (RM)</label>
                             <input
